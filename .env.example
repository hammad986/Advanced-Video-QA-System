# ── Required ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/videoqa
JWT_SECRET=change-me-to-a-random-secret

# ── Queue / Worker ─────────────────────────────────────────────────────
# Leave blank to use the in-process threading.Queue worker (Replit default)
REDIS_URL=redis://localhost:6379
RQ_QUEUE=default
JOB_TIMEOUT_SECONDS=3600
JOB_MAX_RETRIES=3
FFMPEG_TIMEOUT=600

# ── Storage ────────────────────────────────────────────────────────────
# Leave blank to use local disk storage (data/media/)
AWS_S3_BUCKET=your-bucket-name
AWS_ACCESS_KEY_ID=your-key-id
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_SIGNED_URL_EXPIRY=3600     # seconds presigned URLs are valid

# ── Google OAuth ───────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LLM providers ─────────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
HF_TOKEN=
XAI_API_KEY=

# ── Tuning ────────────────────────────────────────────────────────────
VIDEO_QA_MAX_UPLOAD_MB=300
LOCAL_MODE=0                  # 1 = Ollama-only, no cloud LLM calls
BEDROCK_DISABLED=1
